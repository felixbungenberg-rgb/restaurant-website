---
layout: base.njk
title: "Reviews"
---

<style>
  .reviews-page { padding: 4rem 2.5rem 5rem; }

  .reviews-list {
    max-width: 800px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 1.5rem;
  }

  .review-full {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .review-author { font-family: 'Playfair Display', serif; font-size: 1.05rem; }

  .review-source {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--warm);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .review-text { color: var(--mid); line-height: 1.75; margin-bottom: 0.75rem; }

  .review-date { font-size: 0.8rem; color: var(--muted); }
</style>

<div class="page-hero">
  <p class="section-label">Guest Experiences</p>
  <h1 class="section-title light">Reviews</h1>
</div>

<div class="reviews-page">
  <div class="reviews-list">
    {% for review in reviews.reviews %}
    <article class="review-full">
      <div class="review-header">
        <span class="review-author">{{ review.author }}</span>
        <span class="review-source">{{ review.source }}</span>
      </div>
      <div class="stars">
        {% for i in range(review.rating) %}★{% endfor %}
      </div>
      <p class="review-text" style="margin-top:0.6rem">"{{ review.text }}"</p>
      <p class="review-date">{{ review.date }}</p>
    </article>
    {% endfor %}
  </div>
</div>
