    margin-bottom: 0.5rem;
  }

  .wine-item {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
  }

  .wine-item:last-child { border-bottom: none; }

  .wine-item-name {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem; color: var(--cream); margin-bottom: 0.15rem;
  }

  .wine-item-desc { font-size: 0.78rem; color: rgba(237,232,220,0.5); }

  .wine-item-price {
    font-size: 0.85rem; color: rgba(237,232,220,0.7);
    white-space: nowrap; flex-shrink: 0; padding-top: 0.15rem; margin-left: 1rem;
  }

  .wine-note {
    max-width: 820px; margin: 2rem auto 0;
    font-size: 0.78rem; color: rgba(237,232,220,0.4);
    border-top: 0.5px solid rgba(255,255,255,0.08); padding-top: 1.5rem;
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .wine-intro { grid-template-columns: 1fr; }
    .wine-img-block { order: -1; }
  }
</style>

