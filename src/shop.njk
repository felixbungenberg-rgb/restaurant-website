---
layout: base.njk
title: "Shop"
permalink: /shop/
---

<style>
  .shop-page { padding: 4rem 2rem 5rem; background: var(--white); }

  .shop-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .shop-card {
    background: var(--white);
    border: 0.5px solid rgba(167,195,195,0.4);
    border-radius: 4px; overflow: hidden;
    display: flex; flex-direction: column;
    transition: box-shadow 0.2s;
  }

  .shop-card:hover { box-shadow: 0 4px 20px rgba(167,195,195,0.25); }

  .shop-card-img { width: 100%; height: 220px; object-fit: cover; display: block; background: rgba(167,195,195,0.15); }

  .shop-card-img-ph {
    width: 100%; height: 220px;
    background: rgba(167,195,195,0.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
  }

  .shop-card-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .shop-card-name { font-family: 'Playfair Display', serif; font-size: 1rem; margin-bottom: 0.4rem; }
  .shop-card-desc { font-size: 0.82rem; color: var(--muted); flex: 1; margin-bottom: 1.25rem; line-height: 1.6; }
  .shop-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .shop-card-price { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--black); }

  .shop-note {
    max-width: 1100px; margin: 3rem auto 0;
    text-align: center; font-size: 0.82rem; color: var(--muted);
  }
</style>

<div class="page-hero">
  <span class="eyebrow">Strandmuschel</span>
  <h1 class="section-title">Shop</h1>
  <p style="font-size:0.9rem;color:var(--muted);margin-top:0.5rem">Ein Stück Strandmuschel für daheim.</p>
</div>

<div class="shop-page">
  <div class="shop-grid">
    {% for product in shop.products %}
    <article class="shop-card">
      {% if product.image %}
        <img class="shop-card-img" src="{{ product.image }}" alt="{{ product.name }}" loading="lazy">
      {% else %}
        <div class="shop-card-img-ph">Foto folgt</div>
      {% endif %}
      <div class="shop-card-body">
        <h2 class="shop-card-name">{{ product.name }}</h2>
        <p class="shop-card-desc">{{ product.description }}</p>
        <div class="shop-card-footer">
          <span class="shop-card-price">{{ product.price }}</span>
          <a href="{{ product.stripe_link }}" class="btn btn-blue" target="_blank" rel="noopener">Kaufen</a>
        </div>
      </div>
    </article>
    {% endfor %}
  </div>
  <p class="shop-note">
    Bestellungen werden sicher über Stripe abgewickelt. Fragen?
    <a href="mailto:{{ site.email }}" style="color:var(--black)">{{ site.email }}</a>
  </p>
</div>
