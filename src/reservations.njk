---
layout: base.njk
title: "Reservations"
---

<style>
  .reservations-page { padding: 4rem 2.5rem 5rem; }

  .reservations-inner { max-width: 800px; margin: 0 auto; }

  .res-intro {
    font-size: 1.05rem;
    color: var(--mid);
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  .res-embed-box {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    min-height: 300px;
    display: flex; align-items: center; justify-content: center;
  }

  .embed-placeholder {
    text-align: center; color: var(--muted);
  }

  .embed-placeholder p { margin-bottom: 0.5rem; }
  .embed-placeholder code {
    background: var(--warm); padding: 0.2rem 0.5rem;
    border-radius: 3px; font-size: 0.8rem;
  }

  .contact-fallback {
    margin-top: 2.5rem;
    background: var(--warm);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem;
  }

  .contact-fallback h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem; margin-bottom: 0.75rem;
  }
</style>

<div class="page-hero">
  <p class="section-label">{{ site.name }}</p>
  <h1 class="section-title light">Reserve a Table</h1>
</div>

<div class="reservations-page">
  <div class="reservations-inner">
    <p class="res-intro">{{ site.reservation_intro }}</p>

    <div class="res-embed-box">
      {% if site.reservation_system_embed %}
        {{ site.reservation_system_embed | safe }}
      {% else %}
        <div class="embed-placeholder">
          <p>Booking widget will appear here.</p>
          <p>Paste your OpenTable / Resy / Bookatable embed code into the CMS under <code>Site Settings → Reservation Embed</code>.</p>
        </div>
      {% endif %}
    </div>

    <div class="contact-fallback">
      <h3>Prefer to call?</h3>
      <p>For same-day bookings or groups of 8 or more, please call us on <a href="tel:{{ site.phone }}" style="color:var(--gold)">{{ site.phone }}</a> or email <a href="mailto:{{ site.email }}" style="color:var(--gold)">{{ site.email }}</a>.</p>
    </div>
  </div>
</div>
