---
layout: base.njk
title: "Über uns"
permalink: /ueber-uns/
---

<style>
  .about-hero-img {
    width: 100%; height: 460px;
    object-fit: cover; object-position: center 40%;
    display: block;
  }

  .about-page { padding: 4.5rem 2rem 5rem; background: var(--white); }

  .about-inner { max-width: 720px; margin: 0 auto; }

  .about-inner h1 { margin-bottom: 2rem; }

  .about-body { font-size: 1rem; color: var(--muted); line-height: 1.9; }
  .about-body p { margin-bottom: 1.5rem; }

  .about-quote-block {
    background: var(--cream);
    border-left: 3px solid var(--blue);
    padding: 1.75rem 2rem;
    margin: 2.5rem 0;
    border-radius: 0 4px 4px 0;
  }

  .about-quote-block p {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem; font-style: italic;
    color: var(--black); line-height: 1.6; margin-bottom: 0.5rem;
  }

  .about-quote-block cite { font-size: 0.8rem; color: var(--muted); font-style: normal; }

  .about-facts {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; background: rgba(167,195,195,0.35);
    border: 0.5px solid rgba(167,195,195,0.35);
    border-radius: 4px; overflow: hidden;
    margin: 3rem 0;
  }

  .fact {
    background: var(--white);
    padding: 1.5rem;
  }

  .fact-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem; }
  .fact-value { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--black); }

  .gallery-section { padding: 4rem 2rem 5rem; background: var(--white); }

  .gallery-masonry {
    max-width: 1100px; margin: 0 auto;
    columns: 3; column-gap: 0.75rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 0.75rem;
    border-radius: 4px; overflow: hidden;
    background: rgba(167,195,195,0.1);
  }

  .gallery-item img {
    width: 100%; display: block;
    image-orientation: from-image;
    transition: transform 0.4s;
  }

  .gallery-item:hover img { transform: scale(1.02); }

  @media (max-width: 768px) { .gallery-masonry { columns: 2; } }
  @media (max-width: 480px) { .gallery-masonry { columns: 1; } }

  .reviews-section { padding: 4rem 2rem 5rem; background: var(--cream); }

  .google-banner {
    max-width: 820px; margin: 0 auto 3rem;
    background: rgba(167,195,195,0.1);
    border: 0.5px solid rgba(167,195,195,0.4);
    border-radius: 4px; padding: 1.5rem 2rem;
    display: flex; align-items: center; gap: 1.5rem;
  }

  .gb-score { font-family: 'Playfair Display', serif; font-size: 2.5rem; color: var(--black); flex-shrink: 0; }
  .gb-stars { color: #C9A96E; font-size: 1rem; letter-spacing: 2px; margin-bottom: 0.2rem; }
  .gb-label { font-size: 0.8rem; color: var(--muted); }

  .reviews-list {
    max-width: 820px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 1.25rem;
  }

  .review-full {
    background: var(--white);
    border: 0.5px solid rgba(167,195,195,0.35);
    border-radius: 4px; padding: 2rem;
  }

  .review-header {
    display: flex; justify-content: space-between;
    align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.6rem;
  }

  .review-author-name { font-family: 'Playfair Display', serif; font-size: 1rem; }

  .review-platform-badge {
    font-size: 0.65rem; font-family: 'Open Sans', sans-serif;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--muted); background: var(--white);
    border: 0.5px solid rgba(167,195,195,0.4);
    border-radius: 20px; padding: 0.2rem 0.6rem;
  }

  .review-stars { color: #C9A96E; font-size: 0.85rem; letter-spacing: 1px; margin-bottom: 0.65rem; }

  .review-body {
    font-family: 'Playfair Display', serif;
    font-size: 0.9rem; font-style: italic;
    color: var(--black); line-height: 1.7; margin-bottom: 0.5rem;
  }

  .review-date { font-size: 0.75rem; color: var(--muted); }
</style>

<img class="about-hero-img" src="{{ site.about_hero_image }}" alt="Strandmuschel Rantum · Sylt">

<div class="about-page">
  <div class="about-inner">
    <span class="eyebrow">Das Restaurant</span>
    <h1 class="section-title">Eine Strandbude mit Charakter</h1>

    <div class="about-quote-block">
      <p>„{{ site.about_quote }}"</p>
      <cite>— {{ site.about_quote_author }}</cite>
    </div>

    <div class="about-body">
      {{ site.about_body | paragraphs | safe }}
    </div>

    <div class="about-facts">
      <div class="fact">
        <div class="fact-label">Standort</div>
        <div class="fact-value">{{ site.address }}</div>
      </div>
      <div class="fact">
        <div class="fact-label">Öffnungszeiten</div>
        <div class="fact-value">Di – So · ab 12:00 Uhr</div>
      </div>
      <div class="fact">
        <div class="fact-label">Telefon</div>
        <div class="fact-value">{{ site.phone }}</div>
      </div>
      <div class="fact">
        <div class="fact-label">E-Mail</div>
        <div class="fact-value">{{ site.email }}</div>
      </div>
    </div>

    <a href="/reservieren/" class="btn btn-blue">Tisch reservieren</a>
  </div>
</div>

<div class="gallery-section">
  <div class="container" style="margin-bottom:2rem">
    <span class="eyebrow">Impressionen</span>
    <h2 class="section-title">Bilder aus der Strandmuschel</h2>
  </div>
  <div class="gallery-masonry">
    <div class="gallery-item"><img src="/images/hero.jpg" alt="Sonnenuntergang Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_2188.jpeg" alt="Strandkörbe am Abend" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/terrasse.webp" alt="Terrasse" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5227.jpeg" alt="Strandmuschel Sonnenuntergang" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/drinks.webp" alt="Drinks auf der Düne" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5233.jpeg" alt="Terrasse am Abend" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/tapas.webp" alt="Tapas & Bar" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_6811.jpeg" alt="Sonnenuntergang am Strand" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/bar.webp" alt="Bar" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_6820.jpeg" alt="Terrasse im Abendlicht" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5126.jpeg" alt="Sonnenuntergang" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/about.webp" alt="Strandmuschel Außenansicht" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5224.jpeg" alt="Blick auf den Weststrand" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/strand.webp" alt="Weststrand Rantum" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_6772.jpeg" alt="Düne mit Fahne" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/duene.webp" alt="Dünenlandschaft" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5228.jpeg" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/sylt.webp" alt="Sylt Landschaft" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5230.jpeg" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/fahne.webp" alt="Strandmuschel Fahne" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5234.jpeg" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/galerie1.webp" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5235.jpeg" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/galerie2.webp" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_5236.jpeg" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/galerie3.webp" alt="Strandmuschel" loading="lazy"></div>
    <div class="gallery-item"><img src="/images/IMG_6813.jpeg" alt="Strandmuschel" loading="lazy"></div>
  </div>
</div>

<div class="reviews-section">
  <div class="container" style="margin-bottom:2rem">
    <span class="eyebrow">Gästestimmen</span>
    <h2 class="section-title">Was andere sagen</h2>
  </div>
  <div class="google-banner">
    <div class="gb-score">{{ reviews.google_score }}</div>
    <div>
      <div class="gb-stars">★★★★★</div>
      <div class="gb-label">{{ reviews.google_count }} Google-Bewertungen</div>
    </div>
  </div>
  <div class="reviews-list">
    {% for review in reviews.reviews %}
    <article class="review-full">
      <div class="review-header">
        <span class="review-author-name">{{ review.author }}</span>
        <span class="review-platform-badge">{{ review.source }}</span>
      </div>
      <div class="review-stars">{% for i in range(review.rating) %}★{% endfor %}</div>
      <p class="review-body">„{{ review.text }}"</p>
      <p class="review-date">{{ review.date }}</p>
    </article>
    {% endfor %}
  </div>
</div>
