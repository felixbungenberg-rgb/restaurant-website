---
layout: base.njk
title: "Our Story"
---

<style>
  .about-hero-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
    background: var(--dark);
  }

  .about-hero-img-placeholder {
    width: 100%; height: 420px;
    background: linear-gradient(135deg, #2a221a, #1c1713);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.2); font-size: 0.875rem;
    letter-spacing: 0.1em;
  }

  .about-page { padding: 4.5rem 2.5rem 5rem; }

  .about-inner { max-width: 720px; margin: 0 auto; }

  .about-inner .section-label { margin-bottom: 0.75rem; }
  .about-inner .section-title { margin-bottom: 2rem; }

  .about-body {
    font-size: 1.05rem;
    color: var(--mid);
    line-height: 1.85;
  }

  .about-body p { margin-bottom: 1.5rem; }
</style>

{% if site.about_hero_image %}
  <img class="about-hero-img" src="{{ site.about_hero_image }}" alt="{{ site.name }}">
{% else %}
  <div class="about-hero-img-placeholder">Add a hero image in the CMS</div>
{% endif %}

<div class="about-page">
  <div class="about-inner">
    <p class="section-label">Since 1987</p>
    <h1 class="section-title">Our Story</h1>
    <div class="about-body">
      {{ site.about_body | paragraphs | safe }}
    </div>
  </div>
</div>
